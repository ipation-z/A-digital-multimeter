  17   1              
  18   1              I2CCFG |= 0x02;
  19   1          
  20   1          // 清空状态寄存器
  21   1          I2CMSST = 0x00;
  22   1      }
  23          
  24          void Wait()
  25          {
  26   1              while(!(I2CMSST & 0x40));
  27   1              I2CMSST &= ~0x40;  //清楚中断标志
  28   1      }
  29          
  30          void Start()
  31          {
  32   1              I2CMSCR = 0x01; //发送START命令
  33   1              Wait();
  34   1      }
  35          
