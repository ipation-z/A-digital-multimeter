   8          void OLED_WriteCommand(unsigned char Command)
   9          {
  10   1              Start();
  11   1              SendData(0x78);     //寻址
  12   1              RecvACK();
  13   1              SendData(0x00);     //Control Byte
  14   1              RecvACK();
  15   1              SendData(Command);  //Data Byte
  16   1              RecvACK();
  17   1              Stop();
  18   1      }
  19          
  20          void OLED_WriteData(unsigned char Data)
  21          {
