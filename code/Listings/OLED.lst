  32          void OLED_SetCursor(unsigned char X, unsigned char Page)
  33          {
  34   1              OLED_WriteCommand(0x00 | (X & 0x0F) );
  35   1              OLED_WriteCommand(0x10 | ((X & 0xF0) >> 4));
  36   1              OLED_WriteCommand(0xB0 | Page);
  37   1      }
