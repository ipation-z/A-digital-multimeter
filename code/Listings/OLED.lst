 115          void OLED_ShowNum(unsigned char Line, unsigned char Column, int Num, unsigned char Length)
 116          {
C51 COMPILER V9.54   OLED                                                                  03/13/2026 13:12:37 PAGE 3   

 117   1          int i;
 118   1          xdata unsigned char num_str[12];
 119   1          xdata unsigned char temp_str[12];
 120   1          int temp_num = Num;
 121   1              unsigned char actual_length;
 122   1          int index = 0;
 123   1          
 124   1          // 处理负数
 125   1          if (Num < 0)
 126   1          {
 127   2              OLED_ShowChar(Line, Column, '-');
 128   2              Column++;  // 移动到下一列
 129   2              temp_num = -Num;
 130   2              Length--;  // 符号占一位
 131   2          }
 132   1          
 133   1          // 将数字转换为字符串（逆序）
 134   1          if (temp_num == 0)
 135   1          {
 136   2              temp_str[index++] = '0';
 137   2          }
 138   1          else
 139   1          {
 140   2              while (temp_num > 0 && index < 10)
 141   2              {
 142   3                  temp_str[index++] = (temp_num % 10) + '0';
 143   3                  temp_num /= 10;
 144   3              }
 145   2          }
 146   1          
 147   1          // 计算实际数字位数
 148   1          actual_length = index;
 149   1          
 150   1          // 补零并正序存储
 151   1          for (i = 0; i < Length; i++)
 152   1          {
 153   2              if (i < Length - actual_length)
 154   2              {
 155   3                  num_str[i] = '0';  // 前面补零
 156   3              }
 157   2              else
 158   2              {
 159   3                  num_str[i] = temp_str[Length - i - 1];
 160   3              }
 161   2          }
 162   1          num_str[Length] = '\0';
 163   1          
 164   1          // 显示数字
 165   1          for (i = 0; i < Length; i++)
 166   1          {
 167   2              OLED_ShowChar(Line, Column + i, num_str[i]);
 168   2          }
 169   1      }
