  89          void OLED_ShowChar(unsigned char Line, unsigned char Column, char Char)
  90          {
  91   1              int i;
  92   1              unsigned char Page = Line * 2;      // 每行对应2页
  93   1          unsigned char X = Column * 8;       // 每列对应8像素
  94   1              OLED_SetCursor(X, Page);
  95   1              for(i = 0; i < 8; i ++)
  96   1              {
  97   2                      OLED_WriteData(OLED_F8x16[Char - ' '][i]);
  98   2              }
  99   1              OLED_SetCursor(X, Page + 1);
 100   1              for(i = 0; i < 8; i ++)
 101   1              {
 102   2                      OLED_WriteData(OLED_F8x16[Char - ' '][i + 8]);
 103   2              }
 104   1      }
