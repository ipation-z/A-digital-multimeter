  26          
  27          void CD4052_Set_Range(unsigned char Range)
  28          {
  29   1              switch(Range){
  30   2                      case RANGE_200R:      //00 - 200Ω
  31   2                              CD4052_A = 0;
  32   2                              CD4052_B = 0;
  33   2                              break;
  34   2                      case RANGE_2K:        //01 - 2KΩ
  35   2                              CD4052_A = 1;
