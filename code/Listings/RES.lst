  46   2              }
  47   1      }
  48          
  49          float Measure_Resistance(unsigned char range, unsigned int ADValue) {
  50   1          idata float voltage, ref_resistor, resistance;
  51   1          
  52   1          voltage = (ADValue / 4095.0f) * 5.0f;
  53   1          
  54   1          // 获取当前量程的参考电阻值
C51 COMPILER V9.54   RES                                                                   03/13/2026 13:12:37 PAGE 2   

  55   1          ref_resistor = REF_RESISTORS[range];  // 单位：Ω
  56   1          
  57   1          // 开路检测
  58   1          if(voltage > 4.90f)
  59   1              return 0.0f;
  60   1          
  61   1          // 短路检测
  62   1          else if(voltage < 0.10f)
  63   1              return 99999999.0f;
  64   1         
  65   1          // 计算被测电阻值
  66   1          if(ref_resistor > 0 && voltage > 0.1f && voltage < 4.90f) {
  67   2                      if(range == RANGE_200R)
  68   2                      {
  69   3                              if(ADValue < 2600)
  70   3                              resistance = ref_resistor * voltage / (5.0f - voltage) - 310.0f;
  71   3                              else if(ADValue < 2700)
  72   3                              resistance = ref_resistor * voltage / (5.0f - voltage) - 330.0f;
  73   3                              else if(ADValue < 3005)
  74   3                              resistance = ref_resistor * voltage / (5.0f - voltage) - 360.0f;
  75   3                              else if(ADValue < 3050)
  76   3                              resistance = ref_resistor * voltage / (5.0f - voltage) - 300.0f;
  77   3                              else if(ADValue < 3100)
  78   3                              resistance = ref_resistor * voltage / (5.0f - voltage) - 90.0f;
  79   3                              else
  80   3                              resistance = ref_resistor * voltage / (5.0f - voltage);
  81   3                      }
  82   2                      else
  83   2                      resistance = ref_resistor * voltage / (5.0f - voltage);
  84   2          } else {
  85   2              resistance = 0;
  86   2          }
  87   1          
  88   1          return resistance;
  89   1      }


